{
  "dashboard": {
    "title": "WISMO — SLA Performance",
    "uid": "wismo-sla",
    "tags": ["wismo", "sla"],
    "timezone": "browser",
    "refresh": "30s",
    "panels": [
      {
        "title": "API Latency P50 / P95 / P99",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(wismo_api_latency_ms_bucket{route=\"/api/agent/run\"}[5m])) by (le))",
            "legendFormat": "P50"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(wismo_api_latency_ms_bucket{route=\"/api/agent/run\"}[5m])) by (le))",
            "legendFormat": "P95"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(wismo_api_latency_ms_bucket{route=\"/api/agent/run\"}[5m])) by (le))",
            "legendFormat": "P99"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "ms",
            "thresholds": {
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 5000 },
                { "color": "red", "value": 15000 }
              ]
            }
          }
        }
      },
      {
        "title": "Claude API Latency (Haiku vs Opus)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(wismo_claude_latency_ms_bucket{model=\"haiku\"}[5m])) by (le))",
            "legendFormat": "Haiku P95"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(wismo_claude_latency_ms_bucket{model=\"opus\"}[5m])) by (le))",
            "legendFormat": "Opus P95"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "ms" } }
      },
      {
        "title": "Webhook Processing Latency",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(wismo_api_latency_ms_bucket{route=\"/api/gmail/webhook\"}[5m])) by (le))",
            "legendFormat": "Webhook P95"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "ms" } }
      },
      {
        "title": "SLA Compliance (< 60s)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
        "targets": [
          {
            "expr": "sum(rate(wismo_api_latency_ms_bucket{route=\"/api/agent/run\",le=\"60000\"}[1h])) / sum(rate(wismo_api_latency_ms_count{route=\"/api/agent/run\"}[1h])) * 100",
            "legendFormat": "% under 60s"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
      }
    ]
  }
}
